# SQLite paths (created automatically)
COMMUTE_WALLET_DB=data/wallet.db
COMMUTE_BOOKING_DB=data/bookings.db
COMMUTE_PROFILES_DB=data/profiles.db

# --- Geocoding ---
# Free OpenStreetMap Nominatim is used by default for places not in the
# offline India catalog (no API key needed). Set DMOS_USE_NOMINATIM=0 to
# force fully-offline (catalog + haversine only).
DMOS_USE_NOMINATIM=1
# Nominatim's usage policy requires a descriptive, contactable User-Agent.
NOMINATIM_USER_AGENT=DMOS-CommuteSuperapp/1.0 (contact: you@example.com)
# Optional self-hosted / alternate Nominatim endpoint.
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Optional: enable live Google Maps Geocoding + Distance Matrix.
# Leave empty to use the free Nominatim + haversine path above.
GOOGLE_MAPS_API_KEY=

# --- Gemini LLM (optional) ---
# When set, Agents 1/2/5 enrich results via Google Gemini. Leave empty to run
# fully offline on the deterministic parsers. GOOGLE_API_KEY also works.
GEMINI_API_KEY=
# Model id. Defaults to gemini-3.5-flash; override if your account exposes a
# different Flash revision (e.g. gemini-2.5-flash).
GEMINI_MODEL=gemini-3.5-flash

# Streamlit UI
# local = call orchestrator in-process (simplest)
# api   = call FastAPI at DMOS_API_BASE
DMOS_UI_MODE=local
DMOS_API_BASE=http://127.0.0.1:8000
