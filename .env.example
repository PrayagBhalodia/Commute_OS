# SQLite paths (created automatically)
COMMUTE_WALLET_DB=data/wallet.db
COMMUTE_BOOKING_DB=data/bookings.db
COMMUTE_PROFILES_DB=data/profiles.db

# Optional: enable live Google Maps Geocoding + Distance Matrix
# Leave empty to use offline India catalog + haversine model
GOOGLE_MAPS_API_KEY=

# Streamlit UI
# local = call orchestrator in-process (simplest)
# api   = call FastAPI at DMOS_API_BASE
DMOS_UI_MODE=local
DMOS_API_BASE=http://127.0.0.1:8000
