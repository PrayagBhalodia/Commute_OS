# SQLite paths (created automatically)
COMMUTE_WALLET_DB=data/wallet.db
COMMUTE_BOOKING_DB=data/bookings.db
COMMUTE_PROFILES_DB=data/profiles.db

# --- Geocoding (works for any country/state/city worldwide) ---
# Preferred: LocationIQ — free API key with ~5,000 requests/day.
# Sign up at https://locationiq.com, create an Access Token, paste it here.
# It powers geocoding AND the chat agent's place classification (country vs
# state vs city vs specific place), replacing any hardcoded place lists.
LOCATIONIQ_API_KEY=
# LOCATIONIQ_BASE_URL=https://us1.locationiq.com/v1

# Fallback: free OpenStreetMap Nominatim is used automatically when no
# LocationIQ key is set (no API key needed, ~1 req/sec rate limit).
# Set DMOS_USE_NOMINATIM=0 to force fully-offline (catalog + haversine only).
DMOS_USE_NOMINATIM=1
# Nominatim's usage policy requires a descriptive, contactable User-Agent.
NOMINATIM_USER_AGENT=DMOS-CommuteSuperapp/1.0 (contact: you@example.com)
# Optional self-hosted / alternate Nominatim endpoint.
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Optional: enable live Google Maps Geocoding + Distance Matrix.
# Leave empty to use the free Nominatim + haversine path above.
GOOGLE_MAPS_API_KEY=

# --- Gemini LLM (optional) ---
# When set, Agents 1/2/5 enrich results via Google Gemini. Leave empty to run
# fully offline on the deterministic parsers. GOOGLE_API_KEY also works.
GEMINI_API_KEY=
# Flash models are suitable for the Gemini free tier (subject to Google's
# current regional limits and quotas).
GEMINI_MODEL=gemini-2.5-flash

# Streamlit UI
# local = call orchestrator in-process (simplest)
# api   = call FastAPI at DMOS_API_BASE
DMOS_UI_MODE=local
DMOS_API_BASE=http://127.0.0.1:8000

# OpenAI-compatible conversational controller (optional).
# Leave LLM_API_KEY empty for deterministic fallback mode.
# LLM_PROVIDER=auto prefers GEMINI_API_KEY when it is present.
# LLM_PROVIDER=local uses a local OpenAI-compatible server (vLLM /
#   llama.cpp / Ollama) at LLM_BASE_URL — the standard way to serve the
#   Commute OS LoRA adapter; no API key needed.
# LLM_PROVIDER=local_lora loads the adapter in-process via
#   finetuning/inference.py (requires requirements-ml.txt).
LLM_PROVIDER=auto
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
LORA_ADAPTER_PATH=
LORA_BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Local persistent RAG.
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_DB_PATH=data/chroma
RAG_TOP_K=4
RAG_USE_SENTENCE_TRANSFORMERS=0
# Set to 1 once to permit downloading the embedding model. Otherwise the
# private deterministic local embedder is used when the model is not cached.
RAG_ALLOW_MODEL_DOWNLOAD=0
