{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dmos-api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "api.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "dmos-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend", "--", "-p", "3000"],
      "port": 3000
    },
    {
      "name": "dmos-ui",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "streamlit", "run", "ui/app.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    }
  ]
}
